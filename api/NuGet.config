<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- 私有 NuGet 服务器（BaGet），用于 Poxiao Framework 包 -->
    <add key="poxiao-local" value="http://localhost:7000/v3/index.json" allowInsecureConnections="True" />

    <!-- 华为云镜像（国内加速，推荐，已验证可用） -->
    <add key="huaweicloud" value="https://repo.huaweicloud.com/repository/nuget/v3/index.json" allowInsecureConnections="True" />

    <!-- 官方源（备用，国际源） -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" allowInsecureConnections="True" />
  </packageSources>

  <packageSourceMapping>
    <!-- Poxiao 开头的包优先从私有服务器获取 -->
    <packageSource key="poxiao-local">
      <package pattern="Poxiao*" />
    </packageSource>
    <packageSource key="huaweicloud">
      <package pattern="*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
