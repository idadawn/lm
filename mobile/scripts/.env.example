# scripts/.env.example
# 复制本文件为 scripts/.env 并填入真实值。.env 已加入 .gitignore，不要提交。
# 格式：KEY=VALUE，# 开头是注释，空行忽略。

# ──── 蒲公英 (Pgyer) ────
# 必填：API Key（https://www.pgyer.com/account/api）
PGYER_API_KEY=your_pgyer_api_key_here

# 选填：默认更新说明（命令行 -Description 会覆盖）
PGYER_DESCRIPTION=自动构建

# 选填：安装方式 1=公开 / 2=密码 / 3=邀请
PGYER_INSTALL_TYPE=1

# 选填：安装密码（仅当 INSTALL_TYPE=2 时生效）
PGYER_PASSWORD=

# ──── HBuilderX 打包 ────
# 选填：HBuilderX cli.exe 完整路径。空时脚本自动在常用路径搜索
HBUILDER_CLI=

# 选填：云打包最大等待分钟（默认 12）
MAX_WAIT_MINUTES=12

# 选填：是否自动 bump versionCode（true/false，默认 true）
AUTO_BUMP_VERSION=true

# 选填：Android 打包证书类型 0=自定义 / 2=DCloud旧证书 / 3=云证书（默认 3）
ANDROID_PACK_TYPE=3

# ──── 鸿蒙(HarmonyOS) 本地打包 (build-harmony.ps1) ────
# 选填：DevEco Studio / Command Line Tools 安装目录（便于脚本探测；HBuilderX 仍需在设置里配 鸿蒙 DevTools 路径）
DEVECO_HOME=

# 选填：鸿蒙版本更新说明（命令行 -Description 会覆盖）
HARMONY_DESCRIPTION=自动构建

# ──── AppGallery Connect 上传 (upload-to-agc.ps1) ────
# 必填：AGC API 客户端 ID/Secret
#   来源：AGC 控制台 [用户与访问]->[API 客户端]，创建时 Project 保持 N/A（否则 403），至少 运营人员(Operator) 角色
AGC_CLIENT_ID=
AGC_CLIENT_SECRET=
# 必填：AGC 应用 ID（控制台 应用信息页）。需先手动创建 HarmonyOS 应用，bundleName 必须 = com.emergen.lm
AGC_APP_ID=
# 选填：数据处理地域 cn/dre/dra/drru（默认 cn）
AGC_REGION=cn
# 选填：发布类型 1=全网正式(需华为审核) / 6=HarmonyOS 测试(默认，更快)
AGC_RELEASE_TYPE=6
# 选填：上传后是否自动提交审核/发布（true/false，默认 false 仅上传不提审）
AGC_SUBMIT=false
