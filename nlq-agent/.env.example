# ═══════════════════════════════════════════════════════════════
# nlq-agent 环境变量配置
# 复制此文件为 .env 并填入实际值
# ═══════════════════════════════════════════════════════════════

# ── 应用配置 ─────────────────────────────────────────────────
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=18100
DEBUG=true
LOG_LEVEL=info

# ── LLM 配置（vLLM / OpenAI-compatible）─────────────────────
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Embedding 配置（TEI 服务）────────────────────────────────
EMBEDDING_BASE_URL=http://localhost:8001
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024

# ── Qdrant 配置 ──────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# Qdrant Collection 名称
COLLECTION_RULES=lm_judgment_rules
COLLECTION_SPECS=lm_product_specs
COLLECTION_METRICS=lm_metrics

# ── MySQL 配置（路美业务数据库 — 只读账号）───────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=nlq_readonly
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=poxiao_lab
MYSQL_CHARSET=utf8mb4

# ── 检索与 SQL 配置 ─────────────────────────────────────────
RETRIEVAL_TOP_K=5
SQL_MAX_ROWS=500
SQL_TIMEOUT=30

# ── Sentry 错误追踪 ────────────────────────────────────────
# 填入 Sentry DSN 即可启用错误上报；留空则禁用
SENTRY_DSN=

# ── Admin Token（bulk resync 端点鉴权）─────────────────────
SYNC_ADMIN_TOKEN=
