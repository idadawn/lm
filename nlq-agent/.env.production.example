# ═══════════════════════════════════════════════════════════════
# nlq-agent Production 环境变量配置示例
# 复制此文件为 .env.production 并填入真实值
# ⚠️  请勿将真实 secret 提交到版本控制
# ═══════════════════════════════════════════════════════════════

# ── 应用配置 ─────────────────────────────────────────────────
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=18100
DEBUG=false
LOG_LEVEL=info
LOG_FORMAT=json

# ── LLM 配置（生产环境通常使用外部 vLLM / OpenAI-compatible 服务）──
# LLM_BASE_URL: 外部 LLM 推理服务的 OpenAI-compatible 端点
LLM_BASE_URL=http://your-llm-host:8000/v1
# LLM_API_KEY: 如服务无需鉴权可留空
LLM_API_KEY=
# LLM_MODEL: 部署的模型名称
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Embedding 配置（TEI 服务）────────────────────────────────
# EMBEDDING_BASE_URL: TEI 服务地址；若使用 docker-compose.production.yml
# 中的 host 网络模式，宿主机上的 TEI 可直接通过 localhost:8001 访问
EMBEDDING_BASE_URL=http://localhost:8001
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024

# ── Qdrant 配置 ──────────────────────────────────────────────
# QDRANT_HOST: Qdrant 服务地址；生产编排中 Qdrant 与 nlq-agent
# 在同一 Docker network 中，也可使用容器名 nlq-qdrant-prod
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# QDRANT_API_KEY: 如 Qdrant 未启用鉴权可留空
QDRANT_API_KEY=

# Qdrant Collection 名称
COLLECTION_RULES=lm_judgment_rules
COLLECTION_SPECS=lm_product_specs
COLLECTION_METRICS=lm_metrics

# ── MySQL 配置（生产环境连接真实业务数据库 — 只读账号）────────
# MYSQL_HOST: 生产 MySQL 实例地址（不在本 compose 内）
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=nlq_readonly
# MYSQL_PASSWORD: 生产只读账号密码
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=poxiao_lab
MYSQL_CHARSET=utf8mb4

# ── 检索与 SQL 配置 ─────────────────────────────────────────
RETRIEVAL_TOP_K=5
SQL_MAX_ROWS=500
SQL_TIMEOUT=30

# ── Admin Token（bulk resync 端点鉴权，季度轮换）──────────
# SYNC_ADMIN_TOKEN: 用于 POST /api/v1/sync/resync-now 端点鉴权
SYNC_ADMIN_TOKEN=
