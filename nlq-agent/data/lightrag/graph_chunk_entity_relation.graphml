    <node id="Hc">
      <data key="d0">Hc</data>
      <data key="d1">concept</data>
      <data key="d2">Hc is a technical indicator for coercivity, with synonyms including矫顽力, 磁矫顽, and Hc.&lt;SEP&gt;Synonym for the database field F_HC.</data>
      <data key="d3">chunk-d0a625cc09639410176fb4712f0e96c6&lt;SEP&gt;chunk-5e6e25c9fd58e9924568e84459192dcc</data>
      <data key="d4">aliases.json#formula&lt;SEP&gt;aliases.json#field</data>
