    <node id="Labeling Grade">
      <data key="d0">Labeling Grade</data>
      <data key="d1">concept</data>
      <data key="d2">Labeling Grade is the final grade assigned to a strip, which is affected by appearance features.</data>
      <data key="d3">chunk-03f8b5b2f4b11326c72d680e9f3f0c64</data>
