    <node id="F_DeleteMark">
      <data key="d0">F_DeleteMark</data>
      <data key="d1">data</data>
      <data key="d2">A database column used as a filter condition to exclude deleted records.&lt;SEP&gt;A database column indicating deletion status used for filtering.&lt;SEP&gt;A database column for deletion mark, used in the WHERE clause of the SQL template.&lt;SEP&gt;F_DeleteMark is a flag column in lab_intermediate_data; records with NULL F_DeleteMark are considered active.&lt;SEP&gt;A column in the lab_intermediate_data table used to mark logical deletion, filtered by IS NULL condition.&lt;SEP&gt;Column in lab_intermediate_data indicating deletion status.</data>
      <data key="d3">chunk-957813961c6bd225bcd390b432783050&lt;SEP&gt;chunk-a89346ef582d2491429fb4a619ba0c4b&lt;SEP&gt;chunk-eaa469fa109e3da0e7694dbe4aa14741&lt;SEP&gt;chunk-985990948d7ec4a2a0aaa3d3376e6d0b&lt;SEP&gt;chunk-1ffe127439929c413f3cda62f238993b&lt;SEP&gt;chunk-d8158b31ac0e5f48421ac68e0c0b5873</data>
