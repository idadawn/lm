      <data key="d0">LabProductSpec</data>
      <data key="d1">data</data>
      <data key="d2">LabProductSpec is a database table referenced as the data source for ProductSpec nodes. It contains fields like F_Id, F_CODE, F_NAME, F_DETECTION_COLUMNS and is filtered by delete and enabled marks.</data>
