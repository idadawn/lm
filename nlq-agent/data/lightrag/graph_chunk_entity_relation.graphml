    <node id="Offset 2">
      <data key="d0">Offset 2</data>
      <data key="d1">concept</data>
      <data key="d2">Offset 2 is the numeric value used as the second parameter in the DIFF_LAST formula, indicating the number of steps back to compute the difference.</data>
