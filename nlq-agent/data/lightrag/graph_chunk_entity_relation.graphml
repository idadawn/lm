    <node id="MySQL">
      <data key="d0">MySQL</data>
      <data key="d1">artifact</data>
      <data key="d2">A relational database management system used to store decision rules, product specifications, and formula definitions.&lt;SEP&gt;Relational database used as a fallback data source for ontology retrieval when Neo4j is disabled.&lt;SEP&gt;Relational database used as a fallback data source for ontology retrieval when Neo4j is disabled.</data>
      <data key="d3">chunk-6a6cdc66d52ec10ea8f88d70678018b0&lt;SEP&gt;chunk-f9301c28a60e02d9a6907aada6663783</data>
