# ═══════════════════════════════════════════════════════════════
# nlq-agent 环境变量配置（兼容 Pydantic Settings 格式）
# 复制此文件为 .env 并填入实际值
# ═══════════════════════════════════════════════════════════════

# ── 应用配置 ─────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# ── 数据库配置（MySQL）───────────────────────────────────────
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/lab_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis 配置 ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LiteLLM 网关配置 ─────────────────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-litellm-master-key
DEFAULT_MODEL_NAME=deepseek-chat

# ── vLLM 配置 ────────────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8080/v1
VLLM_API_KEY=token-xxx

# ── 直连 LLM 配置（备选）──────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── JWT 认证配置 ──────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── 上游主系统认证校验配置 ────────────────────────────────────
POXIAO_API_BASE_URL=http://localhost:10089
POXIAO_CURRENT_USER_PATH=/api/oauth/CurrentUser
AUTH_REQUIRED=false
AUTH_VALIDATE_UPSTREAM=true
AUTH_CACHE_TTL_SECONDS=300
REQUIRED_PERMISSION_MODULES=lab

# ── LangSmith 可观测性 ───────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nlq-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Neo4j 知识图谱配置 ───────────────────────────────────────
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ── Sentry 错误追踪 ─────────────────────────────────────────
SENTRY_DSN=

# ── CORS 配置 ────────────────────────────────────────────────
CORS_ORIGINS=["*"]
