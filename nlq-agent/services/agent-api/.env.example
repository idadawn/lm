# NLQ-Agent API 环境变量模板

# ── 数据库配置 ──────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/lab_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis 配置 ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LiteLLM 网关配置 ─────────────────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-litellm-master-key

# ── 直连 LLM ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://openrouter.ai/api/v1
GEMINI_API_KEY=AIzaSy-xxx
OLLAMA_BASE_URL=http://localhost:11434

# ── JWT 认证配置 ──────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Neo4j 知识图谱配置 ───────────────────────────────────────
# 设置为 true 启用 Neo4j 知识图谱
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ── 应用配置 ──────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
