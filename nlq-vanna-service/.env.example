# =============================================================================
# nlq-vanna-service 环境变量模板
# 复制此文件为 .env 并填写真实值，不要提交 .env 到版本控制
# =============================================================================

# -----------------------------------------------------------------------------
# MySQL 数据库连接
# -----------------------------------------------------------------------------
MYSQL_HOST=47.105.59.151
MYSQL_PORT=8930
MYSQL_USER=root
MYSQL_PASSWORD=<your-mysql-password>
MYSQL_DATABASE=lumei

# -----------------------------------------------------------------------------
# Qdrant 向量数据库
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
# Collection 名称，修改后需执行 reindex
QDRANT_COLLECTION=nlq_vanna_knowledge

# -----------------------------------------------------------------------------
# Embedding endpoint —— OpenAI 兼容协议（POST /v1/embeddings）
# 支持 OpenAI 官方 / 智谱 BigModel / DashScope(通义) / SiliconFlow / Ollama /
#      vLLM 嵌入模型 / TEI(--enable-openai-compat) 等任何遵循协议的服务
#
# 配置示例（取一即可）：
# (A) OpenAI 官方 — text-embedding-3-small (1536) 或 -large (3072)
#     TEI_URL=https://api.openai.com/v1
#     EMBEDDING_MODEL=text-embedding-3-small
#     TEI_EMBEDDING_DIM=1536
# (B) 智谱 BigModel — embedding-3 (2048) / embedding-2 (1024)
#     TEI_URL=https://open.bigmodel.cn/api/paas/v4
#     EMBEDDING_MODEL=embedding-3
#     TEI_EMBEDDING_DIM=2048
# (C) DashScope 通义 — text-embedding-v3 (1024)
#     TEI_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#     EMBEDDING_MODEL=text-embedding-v3
#     TEI_EMBEDDING_DIM=1024
# (D) SiliconFlow — bge-m3 (1024)
#     TEI_URL=https://api.siliconflow.cn/v1
#     EMBEDDING_MODEL=BAAI/bge-m3
#     TEI_EMBEDDING_DIM=1024
# (E) 本地 Ollama — nomic-embed-text (768)
#     TEI_URL=http://localhost:11434/v1
#     EMBEDDING_MODEL=nomic-embed-text
#     TEI_EMBEDDING_DIM=768
# -----------------------------------------------------------------------------
TEI_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
TEI_EMBEDDING_DIM=1536

# -----------------------------------------------------------------------------
# vLLM 推理服务
# -----------------------------------------------------------------------------
VLLM_URL=http://localhost:8082/v1
# P3 待运维确认：请在 Day 1 前确认实际部署的模型 ID
# 参考值示例：Qwen2.5-Coder-7B-Instruct / deepseek-coder-7b-instruct-v1.5
VLLM_MODEL=<TBD by P3 — confirm with ops before Day 1>

# -----------------------------------------------------------------------------
# 服务自身
# -----------------------------------------------------------------------------
SERVICE_PORT=8088
UVICORN_WORKERS=1

# -----------------------------------------------------------------------------
# 知识版本控制
# 修改 knowledge/*.md 或 qa_examples.yaml 后请 bump 此版本号，
# 服务启动时检测到版本不一致将自动触发 reindex
# -----------------------------------------------------------------------------
KNOWLEDGE_VERSION=v1

# -----------------------------------------------------------------------------
# 鉴权（可选）
# 为空时跳过 Bearer Token 校验；非空时 strict 校验
# -----------------------------------------------------------------------------
AUTH_TOKEN=

# -----------------------------------------------------------------------------
# 日志级别
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
