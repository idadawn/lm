# Secrets — never commit
.env

# Virtual environments
.venv/
venv/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Test / tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Eval reports (generated, not source)
tests/eval/reports/

# Qdrant snapshots (generated at demo time)
snapshots/

# Build artifacts
*.egg-info/
dist/
build/

# NOTE: uv.lock is intentionally NOT ignored.
# It is committed to pin exact dependency versions for reproducible installs.
# Do not add uv.lock here.
