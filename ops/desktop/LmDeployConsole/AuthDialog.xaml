<Window x:Class="LmDeployConsole.AuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OSS 凭据码"
        Width="540"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Microsoft YaHei UI"
        FontSize="13">
    <StackPanel Margin="20">
        <TextBlock TextWrapping="Wrap"
                   Foreground="#465264"
                   Text="凭据码由供应商提供，用于在线更新与发布（内含 OSS 访问凭据）。粘贴凭据码后点击保存即可，无需手工编辑配置文件。" />

        <TextBlock x:Name="StatusText" Margin="0,10,0,0" TextWrapping="Wrap" />

        <TextBlock Text="凭据码" FontWeight="SemiBold" Margin="0,12,0,5" />
        <TextBox x:Name="CodeBox"
                 Height="88"
                 FontFamily="Consolas"
                 FontSize="12"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" />

        <TextBlock x:Name="ErrorText"
                   Foreground="DarkRed"
                   TextWrapping="Wrap"
                   Margin="0,6,0,0"
                   Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CopyButton"
                    Content="复制当前凭据码"
                    Width="128"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="Copy_Click" />
            <Button Content="保存"
                    Width="88"
                    Height="32"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Save_Click" />
            <Button Content="取消"
                    Width="88"
                    Height="32"
                    IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
