<Window x:Class="LmDeployConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="检测室数据分析系统 - 部署控制台"
        Width="1240"
        Height="820"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="WideButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#667085" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="PortBox" TargetType="TextBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="PortLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="PortField" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,16,8" />
        </Style>
    </Window.Resources>

    <Grid Background="#FFFFFF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F6F8FB" BorderBrush="#E1E5EC" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock Text="部署控制台" FontSize="22" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock x:Name="AdminText" Foreground="#667085" Margin="0,0,0,10" />

                    <GroupBox Header="身份授权" Margin="0,0,0,10">
                        <StackPanel Margin="8">
                            <TextBlock x:Name="RoleText" Text="当前身份：未授权" Foreground="#B42318" Margin="0,0,0,8" TextWrapping="Wrap" />
                            <DockPanel>
                                <Button x:Name="AuthorizeButton" Content="输入授权码" Width="116" Height="30" DockPanel.Dock="Left" Click="Authorize_Click" />
                                <Button x:Name="LogoutButton" Content="退出授权" Width="82" Height="30" HorizontalAlignment="Right" Click="Logout_Click" />
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="运行设置" Margin="0,0,0,10">
                        <StackPanel Margin="8">
                            <CheckBox x:Name="AutoStartBox" Content="开机自启动" Margin="0,0,0,6" Click="AutoStart_Click" />
                            <CheckBox x:Name="TrayOnMinimizeBox" Content="最小化到托盘" Margin="0,0,0,6" Click="TraySetting_Click" />
                            <CheckBox x:Name="CloseToTrayBox" Content="点击关闭进入托盘" Margin="0,0,0,8" Click="TraySetting_Click" />
                            <Button Content="隐藏到托盘" Height="30" Click="HideToTray_Click" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="部署位置" Margin="0,0,0,10">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="78" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DeployRootBox" Grid.Column="0" Height="30" />
                            <Button x:Name="BrowseButton" Content="浏览" Grid.Column="1" Height="30" Margin="8,0,0,0" Click="BrowseDeployRoot_Click" />
                        </Grid>
                    </GroupBox>

                    <TextBlock x:Name="BusyText" Text="就绪" Foreground="#465264" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="180" />
            </Grid.RowDefinitions>

            <TabControl x:Name="MainTabs" Grid.Row="0">
                <TabItem Header="安装">
                    <Grid x:Name="InstallPanel" Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <GroupBox Header="推荐端口" Margin="0,0,0,10">
                            <StackPanel Margin="8">
                                <UniformGrid Columns="4" Margin="0,0,0,4">
                                    <StackPanel Style="{StaticResource PortField}">
                                        <TextBlock Text="Web 入口（80）" Style="{StaticResource PortLabel}" />
                                        <TextBox x:Name="WebPortBox" Style="{StaticResource PortBox}" />
                                    </StackPanel>
                                    <StackPanel Style="{StaticResource PortField}">
                                        <TextBlock Text="API（10089）" Style="{StaticResource PortLabel}" />
                                        <TextBox x:Name="ApiPortBox" Style="{StaticResource PortBox}" />
                                    </StackPanel>
                                    <StackPanel Style="{StaticResource PortField}">
                                        <TextBlock Text="智能体（8000）" Style="{StaticResource PortLabel}" />
                                        <TextBox x:Name="NlqPortBox" Style="{StaticResource PortBox}" />
                                    </StackPanel>
                                    <StackPanel Style="{StaticResource PortField}">
                                        <TextBlock Text="MySQL（3306）" Style="{StaticResource PortLabel}" />
                                        <TextBox x:Name="DbPortBox" Style="{StaticResource PortBox}" />
                                    </StackPanel>
                                    <StackPanel Style="{StaticResource PortField}">
                                        <TextBlock Text="Redis（6380）" Style="{StaticResource PortLabel}" />
                                        <TextBox x:Name="RedisPortBox" Style="{StaticResource PortBox}" />
                                    </StackPanel>
                                    <StackPanel Style="{StaticResource PortField}">
                                        <TextBlock Text="RabbitMQ（8005）" Style="{StaticResource PortLabel}" />
                                        <TextBox x:Name="RabbitPortBox" Style="{StaticResource PortBox}" />
                                    </StackPanel>
                                    <StackPanel Style="{StaticResource PortField}">
                                        <TextBlock Text="RabbitMQ 管理台（15672）" Style="{StaticResource PortLabel}" />
                                        <TextBox x:Name="RabbitMgmtPortBox" Style="{StaticResource PortBox}" />
                                    </StackPanel>
                                </UniformGrid>
                                <DockPanel>
                                    <CheckBox x:Name="FirewallBox" Content="保存后放行 Web 端口到防火墙" IsChecked="True" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                    <Button Content="保存部署设置" Width="128" Height="28" HorizontalAlignment="Right" Click="SaveSettings_Click" />
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                <TextBlock Text="基础软件" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="像软件商店一样勾选需要的组件，自动下载到部署目录。" Style="{StaticResource HintText}" />
                                <UniformGrid x:Name="PrereqChecks" Columns="2" Margin="0,0,0,12" />
                                <Button Content="下载所选基础软件" Style="{StaticResource WideButton}" Click="DownloadSelectedPrereqs_Click" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="服务安装" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="安装基础服务和应用服务，会使用左侧保存的端口与部署目录。" Style="{StaticResource HintText}" />
                                <TextBlock Text="基础服务" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <UniformGrid x:Name="InfraChecks" Columns="2" Margin="0,0,0,10" />
                                <TextBlock Text="应用服务" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <UniformGrid x:Name="AppChecks" Columns="2" Margin="0,0,0,12" />
                                <Button Content="安装所选服务" Style="{StaticResource WideButton}" Click="InstallSelected_Click" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="更新">
                    <Grid x:Name="UpdatePanel" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="一键更新" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="读取 OSS 版本清单，自动识别完整包或工具补丁并执行对应策略。" Style="{StaticResource HintText}" />
                            <Button Content="检查并更新" Height="42" Margin="0,0,0,10" Click="RunUpgrade_Click" />
                            <Button Content="安装每日自动更新任务" Style="{StaticResource WideButton}" Click="InstallAutoUpgrade_Click" />
                            <TextBlock x:Name="OssStatusText" Style="{StaticResource HintText}" Margin="0,10,0,6" />
                            <Button Content="配置 OSS 凭据码" Style="{StaticResource WideButton}" Click="OssAuth_Click" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" x:Name="PublishPanel">
                            <TextBlock Text="发布（管理人员）" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="只有管理人员授权后才能发布程序和部署资源到 OSS。" Style="{StaticResource HintText}" />
                            <Button Content="发布工具补丁" Style="{StaticResource WideButton}" Click="PublishToolPatch_Click" />
                            <Button Content="发布完整部署资源" Style="{StaticResource WideButton}" Click="PublishFullRelease_Click" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="服务">
                    <Grid x:Name="ServicePanel" Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <CheckBox x:Name="AutoRefreshBox" Content="自动刷新" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <TextBlock x:Name="LastRefreshText" Foreground="#6B7280" VerticalAlignment="Center" Text="等待刷新..." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="启动选中" Style="{StaticResource ToolbarButton}" Click="StartSelected_Click" />
                                <Button Content="停止选中" Style="{StaticResource ToolbarButton}" Click="StopSelected_Click" />
                                <Button Content="重启选中" Style="{StaticResource ToolbarButton}" Click="RestartSelected_Click" />
                                <Button Content="刷新状态" Style="{StaticResource ToolbarButton}" Click="Refresh_Click" />
                                <Button Content="健康检查" Style="{StaticResource ToolbarButton}" Click="HealthCheck_Click" />
                                <Button Content="打开站点" Style="{StaticResource ToolbarButton}" Click="OpenSite_Click" />
                            </StackPanel>
                        </DockPanel>

                        <DataGrid x:Name="ServiceGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  RowHeight="32">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="选择" Width="52" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Selected, UpdateSourceTrigger=PropertyChanged}"
                                                      Visibility="{Binding CanSelect, Converter={StaticResource BoolToVis}}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="服务" Binding="{Binding Name}" Width="140" IsReadOnly="True" />
                                <DataGridTextColumn Header="说明" Binding="{Binding Title}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="启动类型" Binding="{Binding StartMode}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80" IsReadOnly="True" />
                                <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="80" IsReadOnly="True" />
                                <DataGridTextColumn Header="端口可用" Binding="{Binding PortOpenText}" Width="90" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DockPanel Grid.Row="2" Margin="0,12,0,4">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="刷新日志" Width="86" Height="28" Margin="0,0,8,0" Click="RefreshLog_Click" />
                                <Button Content="打开日志目录" Width="106" Height="28" Margin="0,0,8,0" Click="OpenLogs_Click" />
                                <Button Content="清空操作输出" Width="106" Height="28" Click="ClearServiceOutput_Click" />
                            </StackPanel>
                            <TextBlock Text="服务日志（按服务分类）" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </DockPanel>

                        <TabControl x:Name="LogTabs" Grid.Row="3" SelectionChanged="LogTabs_SelectionChanged">
                            <TabItem Header="操作输出">
                                <TextBox x:Name="ServiceOutputBox"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto" />
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <TabItem Header="备份">
                    <Grid x:Name="BackupPanel" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="数据库备份" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="使用 mysqldump 备份 .env 中配置的 MySQL 数据库。" Style="{StaticResource HintText}" />
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="每日时间" Width="80" VerticalAlignment="Center" />
                                <TextBox x:Name="BackupTimeBox" Width="90" Height="28" HorizontalAlignment="Left" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="保留天数" Width="80" VerticalAlignment="Center" />
                                <TextBox x:Name="BackupKeepDaysBox" Width="90" Height="28" HorizontalAlignment="Left" />
                            </DockPanel>
                            <Button Content="立即备份" Style="{StaticResource WideButton}" Click="BackupNow_Click" />
                            <Button Content="启用每日备份" Style="{StaticResource WideButton}" Click="InstallBackupSchedule_Click" />
                            <Button Content="关闭每日备份" Style="{StaticResource WideButton}" Click="RemoveBackupSchedule_Click" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="备份文件会保存到部署目录的 backups\db 下；计划任务以最高权限运行，适合无人值守服务器。"
                                   TextWrapping="Wrap"
                                   Foreground="#667085" />
                    </Grid>
                </TabItem>
            </TabControl>

            <DockPanel Grid.Row="1" Margin="0,12,0,4">
                <Button Content="清空输出"
                        DockPanel.Dock="Right"
                        Width="86"
                        Height="28"
                        Click="ClearOutput_Click" />
                <TextBlock Text="执行输出" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
            </DockPanel>

            <TextBox x:Name="OutputBox"
                     Grid.Row="2"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />
        </Grid>
    </Grid>
</Window>
