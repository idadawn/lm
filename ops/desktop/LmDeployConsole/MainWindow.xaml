<Window x:Class="LmDeployConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="检测室数据分析系统 - 部署商店"
        Width="1180"
        Height="780"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="WideButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#667085" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="PortBox" TargetType="TextBox">
            <Setter Property="Width" Value="82" />
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Margin" Value="8,0,0,6" />
        </Style>
    </Window.Resources>

    <Grid Background="#FFFFFF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F6F8FB" BorderBrush="#E1E5EC" BorderThickness="0,0,1,0">
                <StackPanel Margin="16">
                    <TextBlock Text="部署商店" FontSize="22" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock x:Name="AdminText" Foreground="#667085" Margin="0,0,0,10" />

                    <GroupBox Header="授权码" Margin="0,0,0,10">
                        <StackPanel Margin="8">
                            <PasswordBox x:Name="AuthCodeBox" Height="30" Margin="0,0,0,8" />
                            <DockPanel>
                                <Button Content="授权/切换" Width="116" Height="30" DockPanel.Dock="Left" Click="Authorize_Click" />
                                <Button Content="退出授权" Width="82" Height="30" HorizontalAlignment="Right" Click="Logout_Click" />
                            </DockPanel>
                            <TextBlock x:Name="RoleText" Text="当前身份：未授权" Foreground="#B42318" Margin="0,8,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="运行设置" Margin="0,0,0,10">
                        <StackPanel Margin="8">
                            <CheckBox x:Name="AutoStartBox" Content="开机自启动" Margin="0,0,0,6" Click="AutoStart_Click" />
                            <CheckBox x:Name="TrayOnMinimizeBox" Content="最小化到托盘" Margin="0,0,0,6" Click="TraySetting_Click" />
                            <CheckBox x:Name="CloseToTrayBox" Content="点击关闭进入托盘" Margin="0,0,0,8" Click="TraySetting_Click" />
                            <Button Content="隐藏到托盘" Height="30" Click="HideToTray_Click" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="部署位置" Margin="0,0,0,10">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="78" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DeployRootBox" Grid.Column="0" Height="30" />
                            <Button Content="浏览" Grid.Column="1" Height="30" Margin="8,0,0,0" Click="BrowseDeployRoot_Click" />
                        </Grid>
                    </GroupBox>

                    <TextBlock x:Name="BusyText" Text="就绪" Foreground="#465264" />
                </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="330" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
                <RowDefinition Height="160" />
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0">
                <TabItem Header="安装">
                    <Grid x:Name="InstallPanel" Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <GroupBox Header="推荐端口" Margin="0,0,0,10">
                            <StackPanel Margin="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Web 入口（80）" VerticalAlignment="Center" />
                                <TextBox x:Name="WebPortBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource PortBox}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="API（10089）" VerticalAlignment="Center" />
                                <TextBox x:Name="ApiPortBox" Grid.Row="0" Grid.Column="3" Style="{StaticResource PortBox}" />
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="智能体（8000）" VerticalAlignment="Center" />
                                <TextBox x:Name="NlqPortBox" Grid.Row="0" Grid.Column="5" Style="{StaticResource PortBox}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Redis（6380）" VerticalAlignment="Center" />
                                <TextBox x:Name="RedisPortBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource PortBox}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="RabbitMQ（8005）" VerticalAlignment="Center" />
                                <TextBox x:Name="RabbitPortBox" Grid.Row="1" Grid.Column="3" Style="{StaticResource PortBox}" />
                                <TextBlock Grid.Row="1" Grid.Column="4" Text="RabbitMQ 管理台（15672）" VerticalAlignment="Center" />
                                <TextBox x:Name="RabbitMgmtPortBox" Grid.Row="1" Grid.Column="5" Style="{StaticResource PortBox}" />
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="MySQL（3306）" VerticalAlignment="Center" />
                                <TextBox x:Name="DbPortBox" Grid.Row="1" Grid.Column="6" Style="{StaticResource PortBox}" HorizontalAlignment="Left" />
                            </Grid>
                            <DockPanel Margin="0,6,0,0">
                                <CheckBox x:Name="FirewallBox" Content="保存后放行 Web 端口到防火墙" IsChecked="True" DockPanel.Dock="Left" />
                                <Button Content="保存部署设置" Width="128" Height="28" HorizontalAlignment="Right" Click="SaveSettings_Click" />
                            </DockPanel>
                            </StackPanel>
                        </GroupBox>
                        <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="基础软件" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="像软件商店一样勾选需要的组件，自动下载到部署目录。" Style="{StaticResource HintText}" />
                            <UniformGrid x:Name="PrereqChecks" Columns="2" Margin="0,0,0,12" />
                            <Button Content="下载所选基础软件" Style="{StaticResource WideButton}" Click="DownloadSelectedPrereqs_Click" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="服务安装" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="安装基础服务和应用服务，会使用左侧保存的端口与部署目录。" Style="{StaticResource HintText}" />
                            <TextBlock Text="基础服务" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <UniformGrid x:Name="InfraChecks" Columns="2" Margin="0,0,0,10" />
                            <TextBlock Text="应用服务" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <UniformGrid x:Name="AppChecks" Columns="2" Margin="0,0,0,12" />
                            <Button Content="安装所选服务" Style="{StaticResource WideButton}" Click="InstallSelected_Click" />
                        </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="更新">
                    <Grid x:Name="UpdatePanel" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="一键更新" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="读取 OSS 版本清单，自动识别完整包或工具补丁并执行对应策略。" Style="{StaticResource HintText}" />
                            <Button Content="检查并更新" Height="42" Margin="0,0,0,10" Click="RunUpgrade_Click" />
                            <Button Content="安装每日自动更新任务" Style="{StaticResource WideButton}" Click="InstallAutoUpgrade_Click" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" x:Name="PublishPanel">
                            <TextBlock Text="发布（管理人员）" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="只有管理人员授权后才能发布程序和部署资源到 OSS。" Style="{StaticResource HintText}" />
                            <Button Content="发布工具补丁" Style="{StaticResource WideButton}" Click="PublishToolPatch_Click" />
                            <Button Content="发布完整部署资源" Style="{StaticResource WideButton}" Click="PublishFullRelease_Click" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="服务">
                    <Grid x:Name="ServicePanel" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="服务选择" Style="{StaticResource SectionTitle}" />
                            <Border BorderBrush="#D9DEE8" BorderThickness="1" Background="White" Padding="8" Margin="0,0,0,12">
                                <StackPanel x:Name="ServiceChecks" />
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="服务控制" Style="{StaticResource SectionTitle}" />
                            <UniformGrid Columns="3" Margin="0,0,0,10">
                                <Button Content="启动选中" Style="{StaticResource PrimaryButton}" Click="StartSelected_Click" />
                                <Button Content="停止选中" Style="{StaticResource PrimaryButton}" Click="StopSelected_Click" />
                                <Button Content="重启选中" Style="{StaticResource PrimaryButton}" Click="RestartSelected_Click" />
                                <Button Content="刷新状态" Style="{StaticResource PrimaryButton}" Click="Refresh_Click" />
                                <Button Content="健康检查" Style="{StaticResource PrimaryButton}" Click="HealthCheck_Click" />
                                <Button Content="查看日志" Style="{StaticResource PrimaryButton}" Click="TailLogs_Click" />
                                <Button Content="打开日志目录" Style="{StaticResource PrimaryButton}" Click="OpenLogs_Click" />
                                <Button Content="打开站点" Style="{StaticResource PrimaryButton}" Click="OpenSite_Click" />
                            </UniformGrid>
                            <CheckBox x:Name="AutoRefreshBox" Content="自动刷新服务状态" IsChecked="True" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="备份">
                    <Grid x:Name="BackupPanel" Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="数据库备份" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="使用 mysqldump 备份 .env 中配置的 MySQL 数据库。" Style="{StaticResource HintText}" />
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="每日时间" Width="80" VerticalAlignment="Center" />
                                <TextBox x:Name="BackupTimeBox" Width="90" Height="28" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="保留天数" Width="80" VerticalAlignment="Center" />
                                <TextBox x:Name="BackupKeepDaysBox" Width="90" Height="28" />
                            </DockPanel>
                            <Button Content="立即备份" Style="{StaticResource WideButton}" Click="BackupNow_Click" />
                            <Button Content="启用每日备份" Style="{StaticResource WideButton}" Click="InstallBackupSchedule_Click" />
                            <Button Content="关闭每日备份" Style="{StaticResource WideButton}" Click="RemoveBackupSchedule_Click" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="备份文件会保存到部署目录的 backups\db 下；计划任务以最高权限运行，适合无人值守服务器。"
                                   TextWrapping="Wrap"
                                   Foreground="#667085" />
                    </Grid>
                </TabItem>
            </TabControl>

            <DockPanel Grid.Row="1" Margin="0,12,0,0">
                <TextBlock Text="服务状态" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                <TextBlock x:Name="LastRefreshText" Foreground="#6B7280" Margin="18,3,0,0" />
            </DockPanel>

            <DataGrid x:Name="ServiceGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="32">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="服务" Binding="{Binding Name}" Width="140" />
                    <DataGridTextColumn Header="说明" Binding="{Binding Title}" Width="*" />
                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="100" />
                    <DataGridTextColumn Header="启动类型" Binding="{Binding StartMode}" Width="100" />
                    <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80" />
                    <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="80" />
                    <DataGridTextColumn Header="端口可用" Binding="{Binding PortOpenText}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <TextBlock Text="执行输出" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Left" />
                <Button Content="清空输出" Width="86" Height="28" HorizontalAlignment="Right" Click="ClearOutput_Click" />
            </DockPanel>

            <TextBox x:Name="OutputBox"
                     Grid.Row="4"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />
        </Grid>
    </Grid>
</Window>
