<Window x:Class="LmDeployConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="检测室数据分析系统 - 部署控制台"
        Width="1240"
        Height="800"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei UI"
        FontSize="13">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F6F8FB" BorderBrush="#E1E5EC" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18">
                    <TextBlock Text="部署控制台" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />
                    <TextBlock x:Name="AdminText" Text="管理员权限：" Margin="0,0,0,14" />

                    <TextBlock Text="脚本目录" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <TextBox x:Name="ScriptsDirBox" IsReadOnly="True" Margin="0,0,0,12" />

                    <TextBlock Text="部署目录" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <TextBox x:Name="DeployRootBox" IsReadOnly="True" Margin="0,0,0,16" />

                    <TextBlock Text="服务选择" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Border BorderBrush="#D9DEE8" BorderThickness="1" Background="White" Padding="8" Margin="0,0,0,18">
                        <StackPanel x:Name="ServiceChecks" />
                    </Border>

                    <TextBlock Text="部署与升级" Style="{StaticResource SectionTitle}" />
                    <UniformGrid Columns="2" Margin="0,0,0,8">
                        <Button Content="下载基础软件" Style="{StaticResource PrimaryButton}" Click="DownloadPrereqs_Click" />
                        <Button Content="渲染配置" Style="{StaticResource PrimaryButton}" Click="RenderConfig_Click" />
                        <Button Content="安装基础服务" Style="{StaticResource PrimaryButton}" Click="InstallInfra_Click" />
                        <Button Content="安装应用服务" Style="{StaticResource PrimaryButton}" Click="InstallApps_Click" />
                        <Button Content="一键部署/更新" Style="{StaticResource PrimaryButton}" Click="DeployAll_Click" />
                        <Button Content="发布工具补丁" Style="{StaticResource PrimaryButton}" Click="PublishToolPatch_Click" />
                        <Button Content="发布完整版本" Style="{StaticResource PrimaryButton}" Click="PublishFullRelease_Click" />
                        <Button Content="检查更新" Style="{StaticResource PrimaryButton}" Click="CheckUpgrade_Click" />
                        <Button Content="立即在线升级" Style="{StaticResource PrimaryButton}" Click="RunUpgrade_Click" />
                        <Button Content="安装自动升级" Style="{StaticResource PrimaryButton}" Click="InstallAutoUpgrade_Click" />
                        <Button Content="管理员重启" Style="{StaticResource PrimaryButton}" Click="RestartAsAdmin_Click" />
                        <Button Content="打开站点" Style="{StaticResource PrimaryButton}" Click="OpenSite_Click" />
                    </UniformGrid>

                    <TextBlock Text="服务控制" Style="{StaticResource SectionTitle}" />
                    <UniformGrid Columns="2" Margin="0,0,0,8">
                        <Button Content="启动选中" Style="{StaticResource PrimaryButton}" Click="StartSelected_Click" />
                        <Button Content="停止选中" Style="{StaticResource PrimaryButton}" Click="StopSelected_Click" />
                        <Button Content="重启选中" Style="{StaticResource PrimaryButton}" Click="RestartSelected_Click" />
                        <Button Content="刷新状态" Style="{StaticResource PrimaryButton}" Click="Refresh_Click" />
                        <Button Content="健康检查" Style="{StaticResource PrimaryButton}" Click="HealthCheck_Click" />
                        <Button Content="查看日志" Style="{StaticResource PrimaryButton}" Click="TailLogs_Click" />
                        <Button Content="打开日志目录" Style="{StaticResource PrimaryButton}" Click="OpenLogs_Click" />
                    </UniformGrid>

                    <CheckBox x:Name="AutoRefreshBox" Content="自动刷新服务状态" IsChecked="True" Margin="0,10,0,8" />
                    <TextBlock x:Name="BusyText" Text="就绪" Foreground="#465264" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <TextBlock Text="服务状态" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                <TextBlock x:Name="LastRefreshText" Foreground="#6B7280" Margin="18,3,0,0" />
            </DockPanel>

            <DataGrid x:Name="ServiceGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="32">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="服务" Binding="{Binding Name}" Width="140" />
                    <DataGridTextColumn Header="说明" Binding="{Binding Title}" Width="*" />
                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="100" />
                    <DataGridTextColumn Header="启动类型" Binding="{Binding StartMode}" Width="100" />
                    <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80" />
                    <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="80" />
                    <DataGridTextColumn Header="端口可用" Binding="{Binding PortOpenText}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>

            <DockPanel Grid.Row="2" Margin="0,12,0,0">
                <TextBlock Text="执行输出" FontSize="16" FontWeight="SemiBold" DockPanel.Dock="Left" />
                <Button Content="清空输出" Width="86" Height="28" HorizontalAlignment="Right" Click="ClearOutput_Click" />
            </DockPanel>

            <TextBox x:Name="OutputBox"
                     Grid.Row="3"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />
        </Grid>
    </Grid>
</Window>
