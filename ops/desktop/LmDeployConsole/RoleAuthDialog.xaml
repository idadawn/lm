<Window x:Class="LmDeployConsole.RoleAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="身份授权"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Microsoft YaHei UI"
        FontSize="13">
    <StackPanel Margin="20">
        <TextBlock TextWrapping="Wrap"
                   Foreground="#465264"
                   Text="请输入授权码。管理人员可发布程序；维护人员可下载安装、更新、控制服务和备份数据库。授权码保存在 ops\.env 的 MANAGER_AUTH_CODE / MAINTAINER_AUTH_CODE。" />

        <TextBlock x:Name="HintText"
                   FontFamily="Consolas"
                   FontSize="12"
                   Foreground="DarkGreen"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"
                   Visibility="Collapsed" />

        <TextBlock Text="授权码" FontWeight="SemiBold" Margin="0,12,0,5" />
        <PasswordBox x:Name="CodeBox" Height="30" />

        <TextBlock x:Name="ErrorText"
                   Foreground="DarkRed"
                   TextWrapping="Wrap"
                   Margin="0,6,0,0"
                   Visibility="Collapsed" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="授权"
                    Width="88"
                    Height="32"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click" />
            <Button Content="取消"
                    Width="88"
                    Height="32"
                    IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
