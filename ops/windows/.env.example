# ============================================================================
#  检测室数据分析系统 —— 部署主配置（单一配置源）
#  复制为 ops/windows/.env 并填入真实值。.env 已 gitignore，不要提交。
#  格式：KEY=VALUE，# 注释，空行忽略。
#
#  这是唯一需要编辑的配置文件。部署时 render-config.ps1 会从这里渲染出：
#    - api 的 ConnectionStrings.<Env>.json / Cache.<Env>.json / EventBus.<Env>.json
#    - api 的 AppSetting.json 里 NlqAgent.BaseUrl
#    - nlq-agent/.env（DATABASE_URL / REDIS_URL / LITELLM / JWT ...）
#    - nginx.conf（端口占位符，由 install-services.ps1 渲染）
#  改完这个文件后重新部署（或 render-config.ps1 + 重启对应服务）即可全量生效。
# ============================================================================

# ──── 部署基本参数 ────
ASPNETCORE_ENVIRONMENT=YY
DEPLOY_ROOT=D:\deploy\lab
# nlq-agent 源码部署位置（自包含，不依赖仓库/worktree 存续）
NLQ_DIR=D:\deploy\lab\nlq-agent

# ──── 端口 ────
# WEB_PORT 是唯一对外暴露的端口（nginx）。其余全部只绑 BIND_ADDR(见下)。
WEB_PORT=80
API_PORT=10089
NLQ_PORT=8000
# 内部服务监听地址：127.0.0.1 = 仅本机可达（只有 nginx 对外）。
# 若确需跨机访问某后端，改成 0.0.0.0 并自行做防火墙。
BIND_ADDR=127.0.0.1

# ──── 数据库 (MySQL)：api(SqlSugar) + nlq 共用 ────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lumei
DB_TYPE=MySql
DB_USER=root
DB_PASSWORD=
MYSQLDUMP_EXE=
DB_BACKUP_TIME=02:30
DB_BACKUP_KEEP_DAYS=14

# ──── Redis：api 缓存(db=2) + nlq(db=0，当前未接线) ────
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB_API=2
REDIS_DB_NLQ=0
REDIS_MAXMEMORY=512mb

# ──── RabbitMQ：api EventBus ────
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=8005
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=

# ──── LLM 网关 (nlq 聊天/Chat2SQL 必需，OpenAI 兼容) ────
# 填真实的 DeepSeek/SiliconFlow/OpenRouter/自建 LiteLLM 地址与 key，否则聊天不可用。
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
NLQ_LLM_MODEL=deepseek-chat
# nlq JWT 密钥（留空则 render 时自动生成一个随机值写入 nlq .env）
NLQ_JWT_SECRET=

# ──── .NET AI 服务（外观特征分析等，默认复用上方 LITELLM_*）────
# 留空则 AI_CHAT_ENDPOINT=LITELLM_BASE_URL，AI_CHAT_API_KEY=LITELLM_API_KEY，
# AI_CHAT_MODEL_ID=NLQ_LLM_MODEL；可按需单独覆盖。
AI_CHAT_ENDPOINT=
AI_CHAT_MODEL_ID=
AI_CHAT_API_KEY=
AI_EMBEDDING_ENDPOINT=http://localhost:8081
AI_EMBEDDING_MODEL=bge-m3

# ──── OSS（.NET 文件服务 + 部署分发 push/pull）────
# .NET 文件服务读取 OSS_PROVIDER 等键；push/pull 脚本复用 OSS_ENDPOINT/BUCKET/AK/SK。
# Provider: Invalid(本地), Minio, Aliyun, QCloud, Qiniu, HuaweiCloud
OSS_PROVIDER=Invalid
# 私有 bucket。AccessKey 建议用 RAM 子账号且仅授权该 bucket 读写。
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=
OSS_ENABLE_HTTPS=false
OSS_ENABLE_CACHE=true
# 对象前缀（bucket 内的目录），不同环境可用不同前缀隔离
OSS_PREFIX=lab-deploy

# 基础软件分发：默认从私有 OSS 下载。设为 Public 可回退到公网下载地址。
PREREQ_SOURCE=OSS
PREREQ_PREFIX=prereqs
BOOTSTRAP_PREFIX=bootstrap
RELEASE_BACKUP_KEEP=5

# ──── 可选：外部工具路径覆盖（留空自动探测/下载）────
NSSM_EXE=D:\deploy\lab\nssm.exe
NGINX_EXE=D:\deploy\lab\nginx\nginx.exe
