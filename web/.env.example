# ═══════════════════════════════════════════════════════════════
# web 前端环境变量配置
# 复制此文件为 .env 并填入实际值（或直接用 .env.development / .env.production）
# ═══════════════════════════════════════════════════════════════

# 资源公共路径,需要以 /开头和结尾
VITE_PUBLIC_PATH = /

# 应用标题
VITE_GLOB_APP_TITLE=实验室数据分析系统

# 应用简称
VITE_GLOB_APP_SHORT_NAME=lm

# 接口地址
VITE_GLOB_API_URL=/dev

# WebSocket基础地址
VITE_GLOB_WEBSOCKET_URL=

# Sentry 错误追踪
# 填入 Sentry DSN 即可启用前端错误上报；留空则禁用
# 格式: https://xxx@yyy.ingest.sentry.io/zzz
VITE_SENTRY_DSN=
